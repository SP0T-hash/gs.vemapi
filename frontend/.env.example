# =============================================================================
# CoreAr / GS VEMAPI — Variáveis de Ambiente (Completo)
# =============================================================================
# Copie este arquivo como .env.local e preencha os valores reais.
# NUNCA commitar este arquivo com valores reais!
# =============================================================================

# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND API
# ═══════════════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:5001

# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE — AC ANGRY Security + GS Database
# ═══════════════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...  # Anon key (pública, pode ir no client)

# ⚠️ NUNCA expor SUPABASE_SERVICE_ROLE_KEY no client-side!
# Usada apenas em API Routes (server-side)
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # Settings → API → service_role key

# ═══════════════════════════════════════════════════════════════════════════════
# PKI / AC ANGRY — Módulos de Segurança
# ═══════════════════════════════════════════════════════════════════════════════
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
PKI_NONCE_SECRET=
AUTH_JWT_SECRET=
PKI_ENCRYPTION_KEY=                   # AES-256 key para criptografar artefatos de certificados
PKI_NONCE_TTL=300000                  # TTL do nonce em ms (default: 5min)

# Rate Limiting
RATE_LIMIT_MAX_LOGIN=5                # Tentativas de login antes de bloquear
RATE_LIMIT_MAX_EMIT=10                # Emissões por minuto
RATE_LIMIT_WINDOW=300000              # Janela em ms (default: 5min)

# Auditoria
AUDIT_RETENTION_DAYS=1825             # 5 anos (LGPD)

# ═══════════════════════════════════════════════════════════════════════════════
# GS AUTH — JWT + Sessão
# ═══════════════════════════════════════════════════════════════════════════════
GS_JWT_SECRET=                        # Gere com: openssl rand -hex 64
GS_JWT_EXPIRES_IN=8h                  # Tempo de expiração do token
GS_REFRESH_TOKEN_EXPIRES_IN=7d        # Tempo de expiração do refresh token

# ═══════════════════════════════════════════════════════════════════════════════
# GS ENCRYPTION — Criptografia de Dados Sensíveis
# ═══════════════════════════════════════════════════════════════════════════════
# AES-256-GCM para CPF, RG, CNH, dados de pagamento
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GS_ENCRYPTION_KEY=
GS_ENCRYPTION_ALGORITHM=aes-256-gcm

# ═══════════════════════════════════════════════════════════════════════════════
# GS SECURITY — Middleware
# ═══════════════════════════════════════════════════════════════════════════════
GS_CORS_ORIGIN=http://localhost:3000,https://vemapi.com.br
GS_RATE_LIMIT_WINDOW=60000            # 1 minuto
GS_RATE_LIMIT_MAX=60                  # 60 requisições/minuto

# ═══════════════════════════════════════════════════════════════════════════════
# STORAGE — Documentos (AWS S3 ou Cloudflare R2)
# ═══════════════════════════════════════════════════════════════════════════════
STORAGE_PROVIDER=s3                   # 's3' ou 'r2'
STORAGE_ENDPOINT=                     # URL do endpoint (R2: https://<id>.r2.cloudflarestorage.com)
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=gs-vemapi-documents
STORAGE_PUBLIC_URL=                   # URL pública base (opcional)
ENCRYPT_UPLOADS=true                  # Criptografar antes do upload

# ═══════════════════════════════════════════════════════════════════════════════
# ASAAS — Gateway de Pagamento
# ═══════════════════════════════════════════════════════════════════════════════
ASAAS_API_KEY=                        # Sua chave de API do Asaas
ASAAS_ENVIRONMENT=sandbox             # 'sandbox' ou 'production'
ASAAS_WALLET_ID=                      # ID da carteira Asaas (para split)
ASAAS_API_URL=https://sandbox.asaas.com/api/v3

# ═══════════════════════════════════════════════════════════════════════════════
# INTEGRAÇÕES — ACs Parceiras
# ═══════════════════════════════════════════════════════════════════════════════
ANGRY_AC_API_KEY=                     # API Key AC ANGRY (se integração direta)
SAFEWEB_API_KEY=                      # API Key Safeweb
VALID_API_KEY=                        # API Key Valid Certisign

# ═══════════════════════════════════════════════════════════════════════════════
# NEXT.JS — Configurações
# ═══════════════════════════════════════════════════════════════════════════════
NEXT_TELEMETRY_DISABLED=1
